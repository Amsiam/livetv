# Copy to deploy/.env on the server: cp env.production.example .env

# Django
DJANGO_SECRET_KEY=generate-a-long-random-string-here
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=tv.test71.xyz,localhost,127.0.0.1
PUBLIC_API_URL=https://tv.test71.xyz
# Optional override (auto-derived from PUBLIC_API_URL when https):
# CSRF_TRUSTED_ORIGINS=https://tv.test71.xyz

# Origin ports — must match deploy/nginx/livetv.conf (listen / upstream)
NGINX_PUBLISH_PORT=8134

# Database (docker service names — do not change HOST in production compose)
POSTGRES_DB=livetv
POSTGRES_USER=livetv
POSTGRES_PASSWORD=strong-db-password-here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis (docker service name)
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API caching & stream health
MATCH_LIST_CACHE_TTL=60
CATALOG_LIST_CACHE_TTL=300
APP_UPDATE_CACHE_TTL=300
CHANNEL_FAILURE_THRESHOLD=100
CELERY_VIEW_FLUSH_CRON_MINUTE=*/5
CELERY_MATCH_STATUS_CRON_MINUTE=*/5
CHANNEL_HEALTH_FAILURE_THRESHOLD=3
STREAM_PROBE_TIMEOUT=5
STREAM_PROBE_CHUNK_SIZE=100
STREAM_PROBE_WORKERS=20
CATALOG_SYNC_CHUNK_SIZE=500

# Celery beat schedules (cron syntax — UTC)
CELERY_SYNC_CRON_HOUR=*/6
CELERY_PROBE_CRON_MINUTE=*/15
CELERY_REACTIVATE_CRON_MINUTE=*/30

# Optional: probe streams during catalog sync (slow)
# CATALOG_SYNC_PROBE_STREAMS=false

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LiveTVCollector catalog sync (celery beat — every 6h by default)
LIVETV_COLLECTOR_REGIONS=Bangladesh,India,Pakistan

# Flutter / web clients (comma-separated origins; include Chrome dev port)
CORS_ALLOWED_ORIGINS=https://tv.test71.xyz,http://localhost:37233
