DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.trycloudflare.com
# Required for correct APK download_url when publishing (use tunnel URL in dev):
# PUBLIC_API_URL=https://xxxx.trycloudflare.com
# Optional explicit tunnel (auto-trusted in DEBUG): CSRF_TRUSTED_ORIGINS=https://xxx.trycloudflare.com

# PostgreSQL (optional — defaults to SQLite when unset)
# POSTGRES_DB=livetv
# POSTGRES_USER=livetv
# POSTGRES_PASSWORD=livetv
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Redis (optional — uses in-memory cache when unset)
# REDIS_URL=redis://localhost:6379/1

# Celery worker + beat (uses Redis; broker defaults to redis://localhost:6379/0)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# STREAM_PROBE_TIMEOUT=5
# STREAM_PROBE_CHUNK_SIZE=100
# STREAM_PROBE_WORKERS=20
# CATALOG_SYNC_CHUNK_SIZE=500
# CELERY_SYNC_CRON_HOUR=*/6
# CELERY_PROBE_CRON_MINUTE=*/15
# CELERY_REACTIVATE_CRON_MINUTE=*/30

MATCH_LIST_CACHE_TTL=60
CATALOG_LIST_CACHE_TTL=300
CHANNEL_FAILURE_THRESHOLD=100
CELERY_VIEW_FLUSH_CRON_MINUTE=*/5
CELERY_MATCH_STATUS_CRON_MINUTE=*/5
# Celery health probes deactivate sooner than user reports:
CHANNEL_HEALTH_FAILURE_THRESHOLD=3

# Telegram alerts when a channel is deactivated (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890

# LiveTVCollector catalog sync (https://github.com/bugsfreeweb/LiveTVCollector)
# LIVETV_COLLECTOR_REGIONS=Bangladesh,India,Pakistan
# LIVETV_COLLECTOR_BASE_URL=https://raw.githubusercontent.com/bugsfreeweb/LiveTVCollector/main/LiveTV
# CATALOG_SYNC_PROBE_STREAMS=false
# CATALOG_SYNC_PROBE_TIMEOUT=5
# CATALOG_SYNC_PROBE_WORKERS=20

# CORS_ALLOWED_ORIGINS=http://localhost:37233

# Logging (stdout — view with docker compose logs)
# LOG_LEVEL=INFO
# APP_LOG_LEVEL=INFO
# DJANGO_LOG_LEVEL=INFO
# CELERY_LOG_LEVEL=INFO
# SQL_LOG_LEVEL=WARNING
